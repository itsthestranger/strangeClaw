{
  "actions": {
    "run": {
      "args_schema": {
        "type": "object",
        "properties": {
          "command": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "command"
        ],
        "additionalProperties": false
      },
      "invoke": [
        "bash",
        "-lc",
        "{command}"
      ],
      "timeout_seconds": 120
    }
  }
}
